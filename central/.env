# ==============================================================================
# Configurazione Zabbix Server Centrale
# ==============================================================================
# IMPORTANTE: cambia le password prima di andare in produzione!
# Per generare password sicure: openssl rand -base64 32

# Versione Zabbix (LTS consigliata)
ZABBIX_VERSION=alpine-7.4.9

# Timezone del sistema
TZ=Europe/Rome

# Nome visualizzato nella barra del frontend Zabbix
ZBX_SERVER_NAME=MSP Zabbix Central

# Database PostgreSQL
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ==============================================================================
# Caddy / Reverse Proxy
# ==============================================================================

# FQDN del frontend Zabbix - deve puntare all'IP pubblico di questo server
# tramite record DNS A/AAAA. Caddy richiederà un certificato Let's Encrypt
# per questo dominio al primo avvio.
ZBX_FQDN=zabbix.msp.example.com

# Email per notifiche di scadenza/errori certificati Let's Encrypt
ACME_EMAIL=admin@msp.example.com

# Cloudflare DNS-01
CLOUDFLARE_EMAIL=change@me.tld
CLOUDFLARE_API_TOKEN=cloudflaretoken

# ==============================================================================
# PostgreSQL Tuning (aggiusta in base a RAM della VM)
# ==============================================================================

# Numero massimo di connessioni simultanee al database
PG_MAX_CONNECTIONS=200

# Memoria condivisa per il buffer del database (consigliato: 25% della RAM)
PG_SHARED_BUFFERS=512MB

# Stima della memoria totale disponibile per il cache del SO (consigliato: 75% della RAM)
PG_EFFECTIVE_CACHE_SIZE=1536MB

# Memoria per operazione di ordinamento/hash per singola query
PG_WORK_MEM=16MB

# Memoria per operazioni di manutenzione (VACUUM, CREATE INDEX, ecc.)
PG_MAINTENANCE_WORK_MEM=128MB

# Costo relativo di una lettura random vs sequenziale (1.1 per SSD, 4.0 per HDD)
PG_RANDOM_PAGE_COST=1.1

# Numero di operazioni I/O concorrenti (200 per SSD, 2 per HDD)
PG_EFFECTIVE_IO_CONCURRENCY=200

# Memoria per i buffer WAL (write-ahead log)
PG_WAL_BUFFERS=16MB

# Percentuale di completamento del checkpoint prima di iniziare il successivo
PG_CHECKPOINT_COMPLETION_TARGET=0.9

# ==============================================================================
# Zabbix Server - Performance
# ==============================================================================

# Timeout massimo (secondi) per agent, SNMP, external checks
ZBX_TIMEOUT=30

# Numero di processi poller per check attivi
ZBX_STARTPOLLERS=10

# Numero di processi poller per host non raggiungibili
ZBX_STARTPOLLERSUNREACHABLE=5

# Numero di processi trapper (ricevono dati da agent attivi e proxy)
ZBX_STARTTRAPPERS=10

# Numero di processi per ICMP ping
ZBX_STARTPINGERS=5

# Numero di processi per network discovery
ZBX_STARTDISCOVERERS=5

# Numero di processi per web monitoring (HTTP checks)
ZBX_STARTHTTPPOLLERS=5

# Memoria per la cache di configurazione (host, item, trigger)
ZBX_CACHESIZE=256M

# Memoria per la cache dei dati storici in attesa di scrittura su DB
ZBX_HISTORYCACHESIZE=128M

# Memoria per l'indice della history cache
ZBX_HISTORYINDEXCACHESIZE=32M

# Memoria per la cache dei trend (dati aggregati orari)
ZBX_TRENDCACHESIZE=64M

# Memoria per la cache dei valori recenti (usata da trigger e calculated item)
ZBX_VALUECACHESIZE=256M

# ==============================================================================
# Backup PostgreSQL
# ==============================================================================

# Frequenza del backup (sintassi cron oppure @daily, @weekly, ecc.)
BACKUP_SCHEDULE=@daily

# Retention: giorni di backup giornalieri conservati
BACKUP_KEEP_DAYS=7

# Retention: settimane di backup settimanali conservati
BACKUP_KEEP_WEEKS=4

# Retention: mesi di backup mensili conservati
BACKUP_KEEP_MONTHS=6
