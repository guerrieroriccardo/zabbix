# ==============================================================================
# Configurazione Zabbix Proxy - Sede Cliente
# ==============================================================================
# Personalizza questo file per OGNI sede cliente!

# Versione Zabbix - DEVE corrispondere al server centrale
ZABBIX_VERSION=alpine-7.4.9

# Timezone del sistema
TZ=Europe/Rome

# Hostname del proxy (deve corrispondere ESATTAMENTE al nome configurato
# nel frontend Zabbix in Administration -> Proxies)
ZBX_PROXY_HOSTNAME=proxy-cliente-acme

# Indirizzo del server Zabbix centrale (FQDN o IP pubblico/VPN)
ZBX_SERVER_HOST=zabbix.msp.example.com

# Identita' TLS PSK (deve corrispondere a quanto configurato nel frontend)
ZBX_TLS_PSK_IDENTITY=PSK-cliente-acme

# Valore PSK (64 caratteri hex). Genera con: openssl rand -hex 32
# Deve corrispondere ESATTAMENTE al valore inserito nel frontend Zabbix
ZBX_TLS_PSK_VALUE=CHANGE_ME_RUN_openssl_rand_hex_32

# ==============================================================================
# Performance - Cache e pollers (scala in base al carico della sede)
# ==============================================================================

# Timeout massimo (secondi) per agent, SNMP, external checks
ZBX_TIMEOUT=30

# Frequenza (secondi) con cui il proxy scarica la configurazione dal server
ZBX_CONFIGFREQUENCY=60

# Frequenza (secondi) con cui il proxy invia i dati raccolti al server
ZBX_DATASENDERFREQUENCY=1

# Frequenza (secondi) dell'heartbeat verso il server centrale
ZBX_HEARTBEATFREQUENCY=60

# Memoria per la cache di configurazione (host, item, trigger)
ZBX_CACHESIZE=64M

# Memoria per la cache dei dati storici in attesa di invio al server
ZBX_HISTORYCACHESIZE=32M

# Memoria per l'indice della history cache
ZBX_HISTORYINDEXCACHESIZE=16M

# Numero di processi poller per check attivi
ZBX_STARTPOLLERS=5

# Numero di processi poller per host non raggiungibili
ZBX_STARTPOLLERSUNREACHABLE=3

# Numero di processi per ICMP ping
ZBX_STARTPINGERS=3

# Numero di processi trapper (ricevono dati da agent attivi locali)
ZBX_STARTTRAPPERS=5

# Numero di processi per network discovery
ZBX_STARTDISCOVERERS=3

# Numero di processi per web monitoring (HTTP checks)
ZBX_STARTHTTPPOLLERS=3

# Numero di processi per ricevere SNMP trap
ZBX_STARTSNMPTRAPPER=1

# ==============================================================================
# Buffer offline (dati conservati se il server centrale e' irraggiungibile)
# ==============================================================================

# Ore di dati bufferizzati localmente se il server e' offline
ZBX_PROXYOFFLINEBUFFER=24

# Ore di dati mantenuti localmente anche dopo l'invio (0 = cancella subito)
ZBX_PROXYLOCALBUFFER=1
